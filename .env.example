# ── Copy this to .env and fill in real values ──────────────────────────────
# Each machine gets its own .env; share the file over Tailscale / 1Password.

# Identity
MACHINE_NAME=macbook-pro                   # matches config/machines.yaml key
MACHINE_ROLE=orchestrator                  # orchestrator | worker

# Shared secret (same value on all machines)
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ── Orchestrator-only settings (MacBook Pro) ────────────────────────────────
QUEUE_HOST=0.0.0.0
QUEUE_PORT=8000
QUEUE_DB_PATH=./data/queue.db

# ── Worker-only settings (ThinkPad / Mac Mini) ─────────────────────────────
WORKER_PORT=8001
ORCHESTRATOR_URL=http://YOUR_MACBOOK_TAILSCALE_IP:8000   # tailscale ip -4 on orchestrator
POLL_INTERVAL_SECONDS=10

# ── AI Agent Assistant API (for assistant_query tasks) ─────────────────────
# URL of the ai_agent_assistant HTTP API (running on MacBook Pro)
ASSISTANT_API_URL=http://100.97.176.37:7890
# Optional API key (must match ASSISTANT_API_KEY in ai_agent_assistant/.config)
ASSISTANT_API_KEY=

# Capabilities this machine claims from the queue (comma-separated)
# macbook-pro:   assistant_run,assistant_query
# mac-mini:      ios_build,xcode,flutter,cocoapods,agent_run,run_script,git_pull,test_run,lint,assistant_query
# thinkpad-x1:   android_build,gradle,python_backend,node_backend,docker,agent_run,run_script,git_pull,test_run,lint,npm_build,assistant_query
MACHINE_CAPABILITIES=git_pull,run_script

# ── No API keys needed — all agents use their CLI (login once per machine) ──
# claude  → claude -p       (Claude Code CLI)
# gemini  → gemini -p       (Gemini CLI)
# codex   → codex exec      (OpenAI Codex CLI)
