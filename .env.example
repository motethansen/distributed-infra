# ── Copy this to .env and fill in real values ──────────────────────────────
# Each machine gets its own .env; share the file over Tailscale / 1Password.

# Identity
MACHINE_NAME=michaels-macbook-pro          # matches config/machines.yaml key
MACHINE_ROLE=orchestrator                  # orchestrator | worker

# Shared secret (same value on all machines)
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ── Orchestrator-only settings (MacBook Pro) ────────────────────────────────
QUEUE_HOST=0.0.0.0
QUEUE_PORT=8000
QUEUE_DB_PATH=./data/queue.db

# ── Worker-only settings (ThinkPad / Mac Mini) ─────────────────────────────
WORKER_PORT=8001
ORCHESTRATOR_URL=http://100.97.176.37:8000   # MacBook Tailscale IP
POLL_INTERVAL_SECONDS=10

# ── AI / LLM API keys (shared across all machines) ─────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
CURSOR_API_KEY=
# Required on workers for the claude agent (MacBook uses `claude -p` CLI instead)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Required for Codex agent (OpenAI)
OPENAI_API_KEY=
