# ── Copy this to .env and fill in real values ──────────────────────────────
# Each machine gets its own .env; share the file over Tailscale / 1Password.

# Identity
MACHINE_NAME=macbook-pro                   # matches config/machines.yaml key
MACHINE_ROLE=orchestrator                  # orchestrator | worker

# Shared secret (same value on all machines)
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ── Orchestrator-only settings (MacBook Pro) ────────────────────────────────
QUEUE_HOST=0.0.0.0
QUEUE_PORT=8000
QUEUE_DB_PATH=./data/queue.db

# ── Worker-only settings (ThinkPad / Mac Mini) ─────────────────────────────
WORKER_PORT=8001
ORCHESTRATOR_URL=http://YOUR_MACBOOK_TAILSCALE_IP:8000   # tailscale ip -4 on orchestrator
POLL_INTERVAL_SECONDS=10

# ── No API keys needed — all agents use their CLI (login once per machine) ──
# claude  → claude -p       (Claude Code CLI)
# gemini  → gemini -p       (Gemini CLI)
# groq    → agent -p        (Cursor agent CLI)
# codex   → codex exec      (OpenAI Codex CLI)
