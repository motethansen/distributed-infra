# Environment & secrets
.env
*.env
.env.*
!.env.example

# machines.yaml contains real Tailscale IPs — use machines.yaml.example as template
config/machines.yaml
!config/machines.yaml.example

# Data (SQLite queue lives here, not in git)
data/
*.db
*.db-journal

# Waha session credentials — persisted by the WhatsApp bridge container
services/whatsapp-bridge/waha-sessions/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
dist/
build/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
logs/
*.log

# macOS
.DS_Store

# launchd plists contain secrets (paths, keys) — use the .plist.example as template
scripts/*.plist
!scripts/*.plist.example

# Editor
.vscode/
.idea/
*.swp
