<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Setup:
    1. Create a venv in this folder:   python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
    2. Replace every YOUR_USERNAME / YOUR_SECRET_KEY_HERE / YOUR_WAHA_API_KEY below.
       (Match INFRA_SECRET_KEY to the rest of the fleet, WAHA_API_KEY to docker-compose.yml.)
    3. Copy to ~/Library/LaunchAgents/, then:
         launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.techstartups.whatsapp-bridge.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.techstartups.whatsapp-bridge</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR_USERNAME/Projects/github/techstartups/distributed-infra/workers/whatsapp-bridge/.venv/bin/python</string>
    <string>/Users/YOUR_USERNAME/Projects/github/techstartups/distributed-infra/workers/whatsapp-bridge/bridge.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/YOUR_USERNAME/Projects/github/techstartups/distributed-infra/workers/whatsapp-bridge</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>ORCHESTRATOR_URL</key>
    <string>http://100.97.176.37:8000</string>
    <key>INFRA_SECRET_KEY</key>
    <string>YOUR_SECRET_KEY_HERE</string>
    <key>WAHA_URL</key>
    <string>http://localhost:3000</string>
    <key>WAHA_API_KEY</key>
    <string>YOUR_WAHA_API_KEY</string>
    <key>BRIDGE_PORT</key>
    <string>3001</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>/tmp/whatsapp-bridge.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/whatsapp-bridge.err</string>
</dict>
</plist>
