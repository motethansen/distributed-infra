# WhatsApp bridge config — copy to .env and fill in values

# Orchestrator URL (MacBook Pro Tailscale IP)
ORCHESTRATOR_URL=http://100.97.176.37:8000

# Same secret key used across all machines
INFRA_SECRET_KEY=your-secret-key-here

# Waha container (running locally on Mac Mini via OrbStack)
WAHA_URL=http://localhost:3000

# Port the bridge listens on (Waha sends webhooks here)
BRIDGE_PORT=3001
